<h1><%= t('views.common.title_show', name: Report.model_name.human) %></h1>

<div class="show-item">
  <%= render @report %>
</div>

<nav class="page-nav">
  <% if current_user.id == @report.user_id %>
    <%= link_to t('views.common.edit', name: Report.model_name.human.downcase), edit_report_path(@report) %>
  <% end %>

  <%= link_to t('views.common.back', name: i18n_pluralize(Report.model_name.human.downcase)), reports_path %>

  <% if current_user.id == @report.user_id %>
    <%= button_to t('views.common.destroy', name: Report.model_name.human.downcase), @report, method: :delete %>
  <% end %>  
</nav>

<p><%= t('views.common.title_index', name: Comment.model_name.human.downcase) %></p>
<% if @comments.present? %>
    <% @comments.each do |comment| %>
    <div class="show-item comments">
    <p>
      <strong><%= t('views.common.create_date', name: Comment.model_name.human.downcase) %>:</strong>
      <%= l comment.created_at, format: :long %>
    </p>
    <p>
      <strong><%= t('views.common.user') %>:</strong>
      <%= comment.display_name %>
    </p>
    <p>
      <strong><%= t('views.common.content_item', name: Comment.model_name.human.downcase) %>:</strong>
      <%= comment.body %>
    </p>
    <% if current_user.id == comment.user_id %>
      <%= button_to t('views.common.destroy', name: Comment.model_name.human.downcase), report_comment_path(@report, comment), method: :delete %>
    <% end %>
    </div>
  <% end %>
<% else %>
  <p><%= t('views.comments.no_comment', name: Comment.model_name.human.downcase) %></p>
<% end %>

<p><%= t('views.common.new', name: Comment.model_name.human.downcase) %></p>
<div class="show-item">
<%= form_with(model: [@report, @comment], url: polymorphic_path([@report, @comment])) do |form| %>
  <div>
    <%= form.label :body, t('views.comments.create'), style: "display: block" %>
    <%= form.text_area :body, required: true %>
  </div>
  
  <div>
    <%= form.submit %>
  </div>
<% end %>
</div>
