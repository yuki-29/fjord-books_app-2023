<h1>ユーザー詳細</h1>
<nav class="user-edit">
  <% if @user.id == current_user.id %>
    <%= link_to "アカウント編集", edit_user_registration_path %>
  <%end%>
</nav>

<div id="users" class="index-items">
<div class="index-item">
<div id="<%= dom_id @user %>">
　 <p>
    <strong>登録日:</strong>
    <%= @user.created_at%>
  </p>
  <p>
    <strong>email:</strong>
    <%= @user.email%>
  </p>
  <p>
    <strong>postal_code:</strong>
    <%= @user.postal_code%>
  </p>
  <p>
    <strong>address:</strong>
    <%= @user.address%>
  </p>
  <p>
    <strong>self_introduction:</strong>
    <%= @user.self_introduction%>
  </p>
</div>
</div>
</div>
<nav>
  <%= link_to "Back", users_path %>
</nav>
